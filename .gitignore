# Jekyll's own build output -- everything under _layouts/ and _includes/
# is real, hand-written site source and must stay tracked.
_site/
.jekyll-cache/
.jekyll-metadata

# LaTeX build artifacts (this branch also carries a copy of latex/ from
# the book repo; only .tex/.bib source is meant to be committed).
*.pdf
*.aux
*.log
*.out
*.toc
*.bbl
*.bcf
*.blg
*.run.xml
*.fdb_latexmk
*.fls
*.synctex.gz
